{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/p/:slug", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/schedule.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/schedules/:slug.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "crons": []
}
